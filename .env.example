# ── Base de données ────────────────────────────────────────────────────────────
# URL PostgreSQL complète avec pgvector activé
# Dev : postgresql+asyncpg://app_user:dev_password@localhost:5432/medecinai
DATABASE_URL=
DATABASE_SSL=false          # true en staging/prod

# ── Redis ──────────────────────────────────────────────────────────────────────
# Dev : redis://localhost:6379/0
REDIS_URL=

# ── Auth0 ──────────────────────────────────────────────────────────────────────
# Créer un tenant sur https://manage.auth0.com → Applications → Create Application
# Type : Regular Web Application (backend) + Single Page Application (frontend)
AUTH0_DOMAIN=               # ex: medecinai-dev.eu.auth0.com
AUTH0_CLIENT_ID=            # Client ID application web
AUTH0_CLIENT_SECRET=        # Client secret application web (NE PAS committer)
AUTH0_AUDIENCE=             # ex: https://api.medecinai.fr
AUTH0_CALLBACK_URL=         # ex: http://localhost:3000/api/auth/callback

# ── Pro Santé Connect / e-CPS (P1 — optionnel en dev) ─────────────────────────
# https://esante.gouv.fr/produits-services/pro-sante-connect
PSC_CLIENT_ID=
PSC_CLIENT_SECRET=
PSC_DISCOVERY_URL=          # ex: https://auth.esante.gouv.fr/auth/realms/esante-wallet/.well-known/openid-configuration

# ── Anthropic (LLM) ────────────────────────────────────────────────────────────
# Clé sur https://console.anthropic.com
ANTHROPIC_API_KEY=          # sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1500
ANTHROPIC_TEMPERATURE=0.15

# ── Modèles IA on-premise ─────────────────────────────────────────────────────
# Téléchargés automatiquement par sentence-transformers au premier lancement
# Voir CLAUDE.md section "AI models (download once)"
EMBEDDING_MODEL_PATH=       # Laisser vide → sentence-transformers télécharge dans ~/.cache
EMBEDDING_MODEL_NAME=almanach/camembert-bio   # MVP ; remplacer par DrBERT/DrBERT-7GB-cased en V1
EMBEDDING_DIMENSION=768
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=cpu          # "cuda" si GPU disponible en dev
RERANKER_MODEL_PATH=        # Laisser vide → téléchargement automatique

# ── RAG pipeline ──────────────────────────────────────────────────────────────
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K_RETRIEVAL=20
RAG_TOP_K_FINAL=5
RAG_MIN_SCORE=0.65
RAG_RRF_K=60
RAG_MMR_LAMBDA=0.65
BM25_INDEX_PATH=            # ex: /tmp/medecinai_bm25.pkl (reconstruit chaque nuit)
HNSW_EF_SEARCH=100

# ── Chiffrement patient ───────────────────────────────────────────────────────
# Dev : valeur hex 64 chars quelconque, jamais celle de prod
# Prod : charger depuis HSM OVHcloud, NE JAMAIS mettre en clair ici
PATIENT_ENCRYPTION_MASTER_KEY=  # ex: a3f1...64 chars hex

# ── Stripe ────────────────────────────────────────────────────────────────────
# Clés de test sur https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=          # sk_test_... (dev) / sk_live_... (prod)
STRIPE_PUBLISHABLE_KEY=     # pk_test_... (dev) / pk_live_... (prod)
STRIPE_WEBHOOK_SECRET=      # whsec_... (obtenu via `stripe listen --forward-to ...` en dev)
STRIPE_PRICE_SOLO=          # price_...
STRIPE_PRICE_CABINET=       # price_...
STRIPE_PRICE_RESEAU=        # price_...

# ── MSSanté / DMP (P1) ────────────────────────────────────────────────────────
MSSANTE_GATEWAY_URL=        # ex: https://gateway.mssante.fr/dmp/v1
MEDECINAI_CERT_FINGERPRINT= # Empreinte certificat logiciel (ANS)

# ── Doctolib API (P1) ─────────────────────────────────────────────────────────
DOCTOLIB_API_BASE_URL=      # https://api.doctolib.fr/v2 (après certification partenaire)

# ── Sources données médicales ─────────────────────────────────────────────────
ATIH_CCAM_URL=              # URL téléchargement CCAM ATIH
HAS_API_BASE=               # URL API catalogue HAS
BDPM_API_URL=               # https://api.open-medicaments.fr ou data.gouv.fr
THERIAQUE_API_URL=          # URL API Thériaque

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development         # "development" | "staging" | "production"
APP_SECRET_KEY=             # Chaîne aléatoire 64 chars pour sessions / CSRF
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Celery ────────────────────────────────────────────────────────────────────
# Dev : amqp://dev_user:dev_password@localhost:5672/medecinai
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=      # Même REDIS_URL que ci-dessus

# ── Emails transactionnels ────────────────────────────────────────────────────
# Dev : utiliser Mailpit (https://mailpit.axllent.org) ou Mailtrap
SMTP_HOST=localhost
SMTP_PORT=1025              # Port Mailpit par défaut
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@medecinai.fr

# ── Monitoring ────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
SENTRY_DSN=                 # Optionnel — laisser vide en dev
